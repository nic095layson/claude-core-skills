ust be `key=value`), you may instead want to raise a clear error there. Which behavior do you want?"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":5690,"cache_read_input_tokens":16984,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":5690},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"72bb7880-6412-4ed3-a71a-db4180339941","uuid":"b31c3137-2296-4504-b1e7-097a0f6eef27","request_id":"req_011CcwL1PnqPhsi1H61kakQw"}
